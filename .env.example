# Optional: analytics (e.g. Plausible, Fathom). Load script only if set, non-blocking.
# PUBLIC_ANALYTICS_ID=

# Optional: CTA URLs. Fallback to #download / #pro if unset.
# PUBLIC_DOWNLOAD_URL=
# PUBLIC_PRO_EXPLORE_URL=

# Netlify Forms: form name (must match form name="..." in the waitlist form).
# Default in code is "waitlist".
# PUBLIC_NETLIFY_FORM_NAME=waitlist

# Public contact email shown in legal pages
# SITE_EMAIL=
