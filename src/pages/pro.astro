---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FileDown, Blocks, PieChart } from '@lucide/astro';

const title = 'Chartlet Pro – Export, Gutenberg & more charts';
const description = 'Pro features: export charts to PDF and PNG, Gutenberg blocks, and more chart types. Upgrade from the free Chartlet plugin.';

const features = [
  {
    title: 'Export to PDF & PNG',
    description: 'Download any chart as a high-quality PDF or PNG for reports, presentations, or print. No extra plugins needed.',
  },
  {
    title: 'Gutenberg blocks',
    description: 'Insert and edit charts directly in the block editor. Visual controls and live preview without touching shortcode syntax.',
  },
  {
    title: 'More chart types',
    description: 'Bubble, Polar Area, Radar, Scatter and other chart types on top of bar and line. More options for colors, legends, and axes.',
  },
];
---

<BaseLayout title={title} description={description} canonicalUrl="https://chartletwp.com/pro">
  <main id="main-content" class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">Chartlet Pro</h1>
    <p class="mt-4 text-lg text-slate-400">
      Everything in the free version, plus features that power reports, editor workflows, and richer charts.
    </p>

    <div class="mt-14 grid gap-8 sm:grid-cols-1 md:grid-cols-3">
      <div class="rounded-xl border border-slate-700/50 bg-deep-800/50 p-6">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent-cyan/10 text-accent-cyan">
          <FileDown size={24} strokeWidth={2} />
        </div>
        <h2 class="mt-5 text-xl font-semibold text-white">{features[0].title}</h2>
        <p class="mt-3 text-slate-400">{features[0].description}</p>
      </div>
      <div class="rounded-xl border border-slate-700/50 bg-deep-800/50 p-6">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent-cyan/10 text-accent-cyan">
          <Blocks size={24} strokeWidth={2} />
        </div>
        <h2 class="mt-5 text-xl font-semibold text-white">{features[1].title}</h2>
        <p class="mt-3 text-slate-400">{features[1].description}</p>
      </div>
      <div class="rounded-xl border border-slate-700/50 bg-deep-800/50 p-6">
        <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent-cyan/10 text-accent-cyan">
          <PieChart size={24} strokeWidth={2} />
        </div>
        <h2 class="mt-5 text-xl font-semibold text-white">{features[2].title}</h2>
        <p class="mt-3 text-slate-400">{features[2].description}</p>
      </div>
    </div>

    <div class="mt-14 rounded-2xl border border-accent-cyan/30 bg-deep-800/50 p-8 text-center">
      <h2 class="text-xl font-semibold text-white">Ready for Pro?</h2>
      <p class="mt-2 text-slate-400">Join the waitlist and we’ll notify you at launch.</p>
      <a href="/#pricing-heading" class="mt-6 inline-block rounded-lg bg-accent-cyan px-6 py-3 font-semibold text-deep-900 transition hover:bg-accent-cyan/90" data-umami-event="waitlist-click">
        Join waitlist
      </a>
    </div>

    <p class="mt-12">
      <a href="/" class="text-accent-cyan hover:underline">← Back to Chartlet</a>
    </p>
  </main>
</BaseLayout>
