---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Terms of Service – Chartlet';
const siteEmail = import.meta.env.PUBLIC_SITE_EMAIL ?? '';
const description = 'Terms of use for Chartlet plugin and chartletwp.com website.';
---

<BaseLayout title={title} description={description} canonicalUrl="https://chartletwp.com/terms-of-service">
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">Terms of Service</h1>
    <p class="mt-2 text-slate-500 text-sm">Last updated: April 2026</p>
    <div class="mt-8 prose prose-invert max-w-none space-y-6 text-slate-400">
      <p>
        By using the Chartlet plugin and/or the chartletwp.com website ("Services"), you agree to these terms.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Use of the plugin</h2>
      <p>
        The Chartlet plugin is provided free of charge under the GPLv2 license, for use in accordance with the WordPress ecosystem and our documentation. You are responsible for ensuring your use complies with applicable laws and your hosting provider's terms.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Limitation of liability</h2>
      <p>
        To the extent permitted by law, we are not liable for indirect, incidental, or consequential damages arising from your use of the Services.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Changes</h2>
      <p>
        We may update these terms from time to time. Continued use of the Services after changes constitutes acceptance of the updated terms.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Data rights</h2>
      <p>
        You have the right to access, correct, or delete your personal data. To exercise these rights, please contact us.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Contact</h2>
      <p>
        For questions about these terms, email us at <a href={`mailto:${siteEmail}`} class="text-accent-cyan hover:underline">{siteEmail}</a>.
      </p>
    </div>
    <p class="mt-12">
      <a href="/" class="text-accent-cyan hover:underline">← Back to Chartlet</a>
    </p>
  </main>
</BaseLayout>
