---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'How to create Pie and Doughnut charts in WordPress via shortcode';
const description = 'Step-by-step guide to adding Pie and Doughnut charts to WordPress using Chartlet shortcode, including all key parameters.';
---

<BaseLayout title={title} description={description} canonicalUrl="https://chartletwp.com/docs/pie-doughnut-chart">
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-12">
    <article>
      <h1 class="text-3xl font-bold text-white sm:text-4xl">{title}</h1>
      <p class="mt-4 text-slate-400">
        Pie and Doughnut charts are ideal for showing part-to-whole values. Chartlet supports both via the same shortcode API.
      </p>

      <section class="mt-10">
        <h2 class="text-xl font-semibold text-white">1. Pie chart shortcode</h2>
        <p class="mt-2 text-slate-400">Use this full shortcode with all major parameters:</p>
        <pre class="mt-4 overflow-x-auto rounded-lg border border-slate-700/50 bg-deep-950 p-4 font-mono text-sm text-slate-300" aria-label="Pie chart shortcode example"><code>[chartlet type="pie" labels="Jan,Feb,Mar" data="10,20,30" colors="#3366cc,#dc3912,#ff9900" title="Title" height="300" suffix="%" prefix="$"]</code></pre>
      </section>

      <section class="mt-10">
        <h2 class="text-xl font-semibold text-white">2. Doughnut chart shortcode</h2>
        <p class="mt-2 text-slate-400">Switch only the <code class="font-mono text-accent-cyan">type</code> value:</p>
        <pre class="mt-4 overflow-x-auto rounded-lg border border-slate-700/50 bg-deep-950 p-4 font-mono text-sm text-slate-300" aria-label="Doughnut chart shortcode example"><code>[chartlet type="doughnut" labels="Jan,Feb,Mar" data="10,20,30" colors="#3366cc,#dc3912,#ff9900" title="Title" height="300" suffix="%" prefix="$"]</code></pre>
      </section>

      <section class="mt-10">
        <h2 class="text-xl font-semibold text-white">3. Parameter reference</h2>
        <ul class="mt-3 space-y-2 text-slate-400">
          <li><span class="text-white font-medium">type</span>: <code class="font-mono">pie</code> or <code class="font-mono">doughnut</code></li>
          <li><span class="text-white font-medium">labels</span>: comma-separated labels</li>
          <li><span class="text-white font-medium">data</span>: comma-separated numeric values</li>
          <li><span class="text-white font-medium">colors</span>: comma-separated HEX colors</li>
          <li><span class="text-white font-medium">title</span>: chart title</li>
          <li><span class="text-white font-medium">height</span>: chart height in pixels</li>
          <li><span class="text-white font-medium">prefix / suffix</span>: format values with currency/units</li>
        </ul>
      </section>

      <p class="mt-12">
        <a href="/docs" class="text-accent-cyan hover:underline">← Back to Docs</a>
      </p>
    </article>
  </main>
</BaseLayout>
