---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Chartlet Docs – Shortcode guides';
const description = 'How to create Bar, Line, Pie, and Doughnut charts in WordPress via shortcode. Step-by-step Chartlet documentation.';
const docs = [
  { href: '/docs/bar-chart', title: 'How to create a Bar chart in WordPress via shortcode' },
  { href: '/docs/line-chart', title: 'How to create a Line chart in WordPress via shortcode' },
  { href: '/docs/pie-doughnut-chart', title: 'How to create Pie and Doughnut charts in WordPress via shortcode' },
];
---

<BaseLayout title={title} description={description} canonicalUrl="https://chartletwp.com/docs">
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">Docs</h1>
    <p class="mt-4 text-slate-400">Shortcode guides for Chartlet charts.</p>
    <ul class="mt-10 space-y-4">
      {docs.map((doc) => (
        <li>
          <a href={doc.href} class="block rounded-lg border border-slate-700/50 bg-deep-800/50 p-4 text-white transition hover:border-accent-cyan/50 hover:text-accent-cyan">
            {doc.title}
          </a>
        </li>
      ))}
    </ul>
    <p class="mt-12">
      <a href="/" class="text-accent-cyan hover:underline">← Back to Chartlet</a>
    </p>
  </main>
</BaseLayout>
