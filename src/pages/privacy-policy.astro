---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Privacy Policy – Chartlet';
const siteEmail = import.meta.env.PUBLIC_SITE_EMAIL ?? '';
const description = 'Chartlet privacy policy. How we handle data and what we collect.';
---

<BaseLayout title={title} description={description} canonicalUrl="https://chartletwp.com/privacy-policy">
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">Privacy Policy</h1>
    <p class="mt-2 text-slate-500 text-sm">Last updated: March 2026</p>
    <div class="mt-8 prose prose-invert max-w-none space-y-6 text-slate-400">
      <p>
        Chartlet (“we”, “our”) respects your privacy. This policy describes how we collect, use, and protect information in connection with the Chartlet WordPress plugin and the chartletwp.com website.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Information we collect</h2>
      <p>
        The Chartlet plugin does not collect or transmit personal data from your WordPress site. If you use our website (e.g. waitlist or contact forms), we may collect the information you submit (such as email address) to respond to your request or manage the waitlist.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">How we use information</h2>
      <p>
        We use the information you provide only for the purposes stated (e.g. to notify you about Chartlet Pro availability). We do not sell your data to third parties.
      </p>
      <p>
        We use your email only to send updates about Chartlet. You can unsubscribe at any time.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Cookies and analytics</h2>
      <p>
        We do not use cookies or any cross-site tracking technologies. To understand how our website is used, we use Umami Analytics—a privacy-first, cookie-less tool. It collects only anonymous, aggregated data and does not store personal information or track you across other websites. Your privacy is respected by default.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Your rights</h2>
      <p>
        You have the right to access, correct, or delete your personal data. You may also request deletion of your email from our waitlist at any time.
      </p>
      <h2 class="text-xl font-semibold text-white mt-10">Contact</h2>
      <p>
        For privacy-related questions or data deletion requests, email us at <a href={`mailto:${siteEmail}`} class="text-accent-cyan hover:underline">{siteEmail}</a>.
      </p>
    </div>
    <p class="mt-12">
      <a href="/" class="text-accent-cyan hover:underline">← Back to Chartlet</a>
    </p>
  </main>
</BaseLayout>
