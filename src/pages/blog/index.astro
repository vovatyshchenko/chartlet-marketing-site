---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/posts';

const title = 'Blog – Chartlet';
const description = 'Articles about WordPress performance, database-less plugins, and Chartlet updates.';
---

<BaseLayout title={title} description={description} canonicalUrl="https://chartletwp.com/blog">
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">Blog</h1>
    <p class="mt-4 text-slate-400">Updates and articles about Chartlet and WordPress performance.</p>
    <ul class="mt-10 space-y-4">
      {blogPosts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`} class="block rounded-lg border border-slate-700/50 bg-deep-800/50 p-4 transition hover:border-accent-cyan/50 group">
            <span class="font-medium text-white group-hover:text-accent-cyan">{post.title}</span>
            <p class="mt-1 text-sm text-slate-500">{post.date}</p>
          </a>
        </li>
      ))}
    </ul>
    <p class="mt-12">
      <a href="/" class="text-accent-cyan hover:underline">← Back to Chartlet</a>
    </p>
  </main>
</BaseLayout>
