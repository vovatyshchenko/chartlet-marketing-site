---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Thanks for joining the waitlist - Chartlet';
const description = 'Your waitlist signup was received successfully.';
---

<BaseLayout title={title} description={description} canonicalUrl="https://chartletwp.com/success" noindex={true}>
  <main id="main-content" class="mx-auto w-full max-w-3xl px-6 py-20">
    <div class="rounded-2xl border border-slate-700/60 bg-deep-800/50 p-8 text-center shadow-xl sm:p-10">
      <p class="text-sm font-semibold uppercase tracking-wide text-accent-cyan">Success</p>
      <h1 class="mt-3 text-3xl font-bold text-white sm:text-4xl">You're on the Chartlet Pro waitlist.</h1>
      <p class="mx-auto mt-4 max-w-xl text-slate-400">
        Thanks for signing up. We will email you when Chartlet Pro is ready.
      </p>
      <a
        href="/#pricing-heading"
        class="mt-8 inline-block rounded-lg bg-accent-cyan px-6 py-3 font-semibold text-deep-900 transition hover:bg-accent-cyan/90"
      >
        Back to homepage
      </a>
    </div>
  </main>
</BaseLayout>
