---
const formName = import.meta.env.PUBLIC_NETLIFY_FORM_NAME ?? 'waitlist';
const isSuccess = Astro.url.searchParams.get('success') === '1';
---

<section class="px-6 py-16 sm:py-24" aria-labelledby="pricing-heading">
  <div class="mx-auto max-w-lg">
    <h2 id="pricing-heading" class="text-center text-3xl font-bold text-white sm:text-4xl">
      Chartlet Pro
    </h2>
    <p class="mx-auto mt-4 max-w-md text-center text-slate-400">
      More chart types, more options. Join the waitlist and we’ll notify you at launch.
    </p>
    <div class="mt-14 rounded-2xl border border-slate-700/50 bg-deep-800/50 p-8 shadow-xl">
      {isSuccess && (
        <p class="mb-6 rounded-lg bg-accent-cyan/10 border border-accent-cyan/30 px-4 py-3 text-accent-cyan" role="status">
          Thanks! You’re on the list. We’ll be in touch.
        </p>
      )}
      <h3 class="text-xl font-semibold text-white">Join the waitlist</h3>
      <form
        name={formName}
        method="POST"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        action="/?success=1"
        class="mt-6 space-y-4"
      >
        <input type="hidden" name="form-name" value={formName} />
        <p class="hidden" aria-hidden="true">
          <label>Don’t fill this out if you’re human: <input name="bot-field" type="text" autocomplete="off" /></label>
        </p>
        <div>
          <label for="waitlist-email" class="block text-sm font-medium text-slate-300">Email</label>
          <input
            id="waitlist-email"
            type="email"
            name="email"
            required
            autocomplete="email"
            class="mt-1 block w-full rounded-lg border border-slate-600 bg-deep-900 px-4 py-3 text-white placeholder-slate-500 focus:border-accent-cyan focus:outline-none focus:ring-1 focus:ring-accent-cyan"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label for="waitlist-name" class="block text-sm font-medium text-slate-300">Name (optional)</label>
          <input
            id="waitlist-name"
            type="text"
            name="name"
            autocomplete="name"
            class="mt-1 block w-full rounded-lg border border-slate-600 bg-deep-900 px-4 py-3 text-white placeholder-slate-500 focus:border-accent-cyan focus:outline-none focus:ring-1 focus:ring-accent-cyan"
            placeholder="Your name"
          />
        </div>
        <div class="flex items-start gap-3 pt-1">
          <input
            id="waitlist-consent"
            type="checkbox"
            name="privacy_consent"
            value="yes"
            required
            class="mt-1 h-4 w-4 rounded border-slate-500 bg-deep-900 text-accent-cyan focus:ring-accent-cyan"
          />
          <label for="waitlist-consent" class="text-sm text-slate-400">
            I agree to the <a href="/privacy-policy" class="text-accent-cyan hover:underline">Privacy Policy</a>.
          </label>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-accent-cyan px-4 py-3 font-semibold text-deep-900 transition hover:bg-accent-cyan/90 focus:outline-none focus:ring-2 focus:ring-accent-cyan focus:ring-offset-2 focus:ring-offset-deep-800"
          data-umami-event="waitlist-submit"
        >
          Join waitlist
        </button>
      </form>
    </div>
  </div>
</section>
