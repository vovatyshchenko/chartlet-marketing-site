---
import ChartDemo from './ChartDemo.tsx';
---

<section class="px-6 py-16 sm:py-24" aria-labelledby="demo-heading">
  <div class="mx-auto max-w-5xl">
    <h2 id="demo-heading" class="text-center text-3xl font-bold text-white sm:text-4xl">
      Live demo
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-slate-400">
      The same Chart.js–powered output you get from the plugin. No backend, no DB—just the chart.
    </p>
    <div class="mt-14 rounded-xl border border-slate-700/50 bg-deep-800/50 p-6 sm:p-8">
      <div class="h-[320px] w-full sm:h-[360px]" aria-hidden="true">
        <ChartDemo client:visible variant="line" />
      </div>
    </div>
  </div>
</section>
