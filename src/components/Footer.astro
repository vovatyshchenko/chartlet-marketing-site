---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800/50 bg-deep-950 mt-auto">
  <div class="mx-auto max-w-6xl px-6 py-8">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-slate-500">
        © {year} Chartlet. Charts without the bloat.
      </p>
      <ul class="flex flex-wrap items-center gap-4 text-sm sm:gap-6">
        <li><a href="/" class="text-slate-400 transition hover:text-white">Home</a></li>
        <li><a href="/docs" class="text-slate-400 transition hover:text-white">Docs</a></li>
        <li><a href="/blog" class="text-slate-400 transition hover:text-white">Blog</a></li>
        <li><a href="/changelog" class="text-slate-400 transition hover:text-white">Changelog</a></li>
        <li><a href="/pro" class="text-slate-400 transition hover:text-white">Pro</a></li>
        <li><a href="/privacy-policy" class="text-slate-400 transition hover:text-white">Privacy Policy</a></li>
        <li><a href="/terms-of-service" class="text-slate-400 transition hover:text-white">Terms of Service</a></li>
      </ul>
    </div>
  </div>
