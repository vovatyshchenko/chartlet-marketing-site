---
import { Zap, ShieldCheck, Sparkles } from '@lucide/astro';
import AnimatedSection from './AnimatedSection.tsx';
---

<section class="px-6 py-16 sm:py-24 bg-deep-800/30" aria-labelledby="features-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="features-heading" class="text-center text-3xl font-bold text-white sm:text-4xl">
      Built for modern WordPress
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-slate-400">
      Speed, privacy, and a dead-simple experience.
    </p>
    <div class="mt-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      <AnimatedSection client:visible>
        <div class="rounded-xl border border-slate-700/50 bg-deep-800/50 p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent-cyan/10 text-accent-cyan">
            <Zap size={24} strokeWidth={2} />
          </div>
          <h3 class="mt-5 text-xl font-semibold text-white">Speed</h3>
          <p class="mt-3 text-slate-400">
            No database writes. Charts live in your content. Fast first load and no extra queries.
          </p>
        </div>
      </AnimatedSection>
      <AnimatedSection client:visible>
        <div class="rounded-xl border border-slate-700/50 bg-deep-800/50 p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent-cyan/10 text-accent-cyan">
            <ShieldCheck size={24} strokeWidth={2} />
          </div>
          <h3 class="mt-5 text-xl font-semibold text-white">Privacy / GDPR</h3>
          <p class="mt-3 text-slate-400">
            No tracking, no external requests. Your data stays on your server. Chartlet is GDPR-friendly by design.
          </p>
        </div>
      </AnimatedSection>
      <AnimatedSection client:visible>
        <div class="rounded-xl border border-slate-700/50 bg-deep-800/50 p-8 sm:col-span-2 lg:col-span-1">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent-cyan/10 text-accent-cyan">
            <Sparkles size={24} strokeWidth={2} />
          </div>
          <h3 class="mt-5 text-xl font-semibold text-white">Simple UX</h3>
          <p class="mt-3 text-slate-400">
            Native Gutenberg block or classic shortcode — your choice. Edit data inline. No dashboards or settings bloat.
          </p>
        </div>
      </AnimatedSection>
    </div>
  </div>
</section>
