---
import ChartDemo from './ChartDemo.tsx';
---

<section class="px-6 py-16 sm:py-24" aria-labelledby="code-heading">
  <div class="mx-auto max-w-6xl">
    <h2 id="code-heading" class="text-center text-3xl font-bold text-white sm:text-4xl">
      One shortcode, full control
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-slate-400">
      Use the full Chartlet shortcode with labels, data, colors, title, height, and value prefix/suffix.
    </p>
    <div class="mt-14 grid min-w-0 gap-8 lg:grid-cols-2 lg:gap-12 items-center">
      <div class="min-w-0 rounded-xl border border-slate-700/50 bg-deep-950 p-6">
        <p class="mb-3 text-sm font-medium text-slate-500">Shortcode</p>
        <pre class="max-w-full min-w-0 overflow-x-auto rounded-lg bg-deep-900 p-4 font-mono text-sm text-slate-300" aria-label="Example Chartlet shortcode"><code class="whitespace-pre">[chartlet type="pie" labels="Jan,Feb,Mar" data="10,20,30" colors="#3366cc,#dc3912,#ff9900" title="Title" height="300" suffix="%" prefix="$"]</code></pre>
      </div>
      <div class="rounded-xl border border-slate-700/50 bg-deep-800/50 p-6 min-h-[280px] flex items-center justify-center" aria-hidden="true">
        <div class="w-full max-w-sm h-[260px]">
          <ChartDemo client:visible />
        </div>
      </div>
    </div>
  </div>
</section>
