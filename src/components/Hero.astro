---
const downloadUrl = import.meta.env.PUBLIC_DOWNLOAD_URL ?? '#download';
const proExploreUrl = import.meta.env.PUBLIC_PRO_EXPLORE_URL ?? '#pro';
---

<section class="relative overflow-hidden px-6 py-20 sm:py-28 lg:py-36">
  <div class="mx-auto max-w-4xl text-center">
    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
      Charts without the Bloat
    </h1>
    <p class="mt-6 text-lg text-slate-400 sm:text-xl max-w-2xl mx-auto">
      Beautiful WordPress charts from a simple shortcode. Zero database overhead, no extra tables, no slowdowns.
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a
        href={downloadUrl}
        class="inline-flex items-center rounded-lg bg-accent-cyan px-6 py-3 text-base font-semibold text-deep-900 shadow-lg transition hover:bg-accent-cyan/90 focus:outline-none focus:ring-2 focus:ring-accent-cyan focus:ring-offset-2 focus:ring-offset-deep-900"
        target="_blank"
        data-umami-event="download-click"
      >
        Download Free
      </a>
      <a
        href={proExploreUrl}
        class="inline-flex items-center rounded-lg border border-slate-600 bg-deep-800/50 px-6 py-3 text-base font-semibold text-white transition hover:border-accent-cyan/50 hover:bg-deep-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 focus:ring-offset-deep-900"
        data-umami-event="pro-click"
      >
        Explore Pro
      </a>
    </div>
  </div>
</section>
