---
---

<section class="px-6 py-16 sm:py-24 bg-deep-800/30" aria-labelledby="comparison-heading">
  <div class="mx-auto max-w-4xl">
    <h2 id="comparison-heading" class="text-center text-3xl font-bold text-white sm:text-4xl">
      Chartlet vs traditional chart plugins
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-slate-400">
      Less database, less code, faster pages.
    </p>
    <div class="mt-14 overflow-hidden rounded-xl border border-slate-700/50 bg-deep-800/50">
      <table class="min-w-full divide-y divide-slate-700" role="table">
        <thead>
          <tr>
            <th scope="col" class="py-4 pl-6 pr-4 text-left text-sm font-semibold text-white">Metric</th>
            <th scope="col" class="py-4 px-4 text-left text-sm font-semibold text-accent-cyan">Chartlet</th>
            <th scope="col" class="py-4 pl-4 pr-6 text-left text-sm font-semibold text-slate-400">Traditional chart plugins</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-700">
          <tr>
            <td class="py-4 pl-6 pr-4 text-sm text-slate-300">Database size</td>
            <td class="py-4 px-4 text-sm font-medium text-white">Zero extra tables</td>
            <td class="py-4 pl-4 pr-6 text-sm text-slate-400">Often 5–20+ tables</td>
          </tr>
          <tr>
            <td class="py-4 pl-6 pr-4 text-sm text-slate-300">Load time impact</td>
            <td class="py-4 px-4 text-sm font-medium text-white">Minimal (shortcode only)</td>
            <td class="py-4 pl-4 pr-6 text-sm text-slate-400">Heavy (DB + options + assets)</td>
          </tr>
          <tr>
            <td class="py-4 pl-6 pr-4 text-sm text-slate-300">Data storage</td>
            <td class="py-4 px-4 text-sm font-medium text-white">In post content</td>
            <td class="py-4 pl-4 pr-6 text-sm text-slate-400">Custom post types / meta</td>
          </tr>
          <tr>
            <td class="py-4 pl-6 pr-4 text-sm text-slate-300">Setup</td>
            <td class="py-4 px-4 text-sm font-medium text-white">Install and use shortcode</td>
            <td class="py-4 pl-4 pr-6 text-sm text-slate-400">Wizards, settings, imports</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
