---
const downloadUrl = import.meta.env.PUBLIC_DOWNLOAD_URL ?? 'https://wordpress.org/plugins/chartlet/';

const steps = [
  {
    number: '1',
    title: 'Install',
    description: 'Go to WordPress → Plugins → Add New, search for «Chartlet», and click Install Now.',
  },
  {
    number: '2',
    title: 'Activate',
    description: 'Click Activate. No configuration required — the plugin is ready immediately.',
  },
  {
    number: '3',
    title: 'Add a chart',
    description: 'Insert the Chartlet block in the block editor, or paste a shortcode into any post or page. Your chart appears instantly.',
  },
];
---

<section class="px-6 py-16 sm:py-24" aria-labelledby="get-started-heading">
  <div class="mx-auto max-w-4xl">
    <h2 id="get-started-heading" class="text-center text-3xl font-bold text-white sm:text-4xl">
      Get started in 3 steps
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-slate-400">
      Free forever. No account required.
    </p>
    <div class="mt-14 grid gap-8 sm:grid-cols-3">
      {steps.map((step) => (
        <div class="rounded-xl border border-slate-700/50 bg-deep-800/50 p-8">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-cyan/10 text-accent-cyan font-bold text-lg">
            {step.number}
          </div>
          <h3 class="mt-5 text-xl font-semibold text-white">{step.title}</h3>
          <p class="mt-3 text-slate-400">{step.description}</p>
        </div>
      ))}
    </div>
    <div class="mt-12 text-center">
      <a
        href={downloadUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg bg-accent-cyan px-8 py-3 text-base font-semibold text-deep-900 shadow-lg transition hover:bg-accent-cyan/90 focus:outline-none focus:ring-2 focus:ring-accent-cyan focus:ring-offset-2 focus:ring-offset-deep-900"
        data-umami-event="get-started-download-click"
      >
        Download from WordPress.org
      </a>
    </div>
  </div>
</section>
